# --- Required ---
# Telegram bot token from @BotFather. The bot will not start without it.
TG_TOKEN=""

# --- Optional ---
# Telegram chat id that receives error reports. If unset, errors are only
# logged locally (the bot keeps running).
DEVELOPER_CHAT_ID=""

# Informational version tag.
VERSION="0.0.1"

# --- Tunables (all optional; safe defaults applied when unset/invalid) ---
# Radius, in kilometers, that defines "around you". Default: 5
TCHAKA_RANGE_KM="5"

# Idle time-to-live, in seconds, before an inactive user is auto-evicted.
# Default: 3600 (~1 hour)
TCHAKA_IDLE_TTL_SECONDS="3600"

# How often, in seconds, the idle-eviction sweep runs. Default: 300 (5 min)
TCHAKA_SWEEP_INTERVAL_SECONDS="300"

# Maximum characters of a relayed message body before truncation. Default: 500
TCHAKA_MAX_RELAY_CHARS="500"

# Maximum characters of an error report sent to the developer chat. Must stay
# under Telegram's 4096-char limit. Default: 3500
TCHAKA_MAX_ERROR_CHARS="3500"
